# Digit9 PaaS sandbox credentials. Get these from your Digit9 integration manager.
# DO NOT COMMIT THE FILLED-IN .env

# Sandbox endpoints
D9_BASE_URL=https://drap-sandbox.digitnine.com
D9_WEBCOMPONENT_BASE_URL=https://drap-sbx.digitnine.com

# OAuth2 (Keycloak password grant)
D9_CLIENT_ID=cdp_app
D9_CLIENT_SECRET=
D9_USERNAME=
D9_PASSWORD=

# The four required context headers
D9_SENDER=
D9_CHANNEL=Direct
D9_COMPANY=
D9_BRANCH=

# HMAC secret for verifying inbound webhooks (issued separately)
D9_WEBHOOK_SECRET=

# Local server config
PORT=3000
WEBHOOK_RECEIVER_URL=http://localhost:3000/webhooks/digit9
